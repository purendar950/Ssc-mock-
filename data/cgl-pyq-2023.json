        {
          "en": "The simple interest on ₹5,000 at 8% per annum for 2 years is?",
          "hi": "₹5,000 पर 8% वार्षिक दर से 2 वर्ष का साधारण ब्याज कितना है?",
          "options": {
            "A": { "en": "₹800", "hi": "₹800" },
            "B": { "en": "₹400", "hi": "₹400" },
            "C": { "en": "₹1,000", "hi": "₹1,000" },
            "D": { "en": "₹640", "hi": "₹640" }
          },
          "correct": "A",
          "explanation": { "en": "SI = P×R×T/100 = 5000×8×2/100 = ₹800.", "hi": "साधारण ब्याज = मूलधन×दर×समय/100 = 5000×8×2/100 = ₹800।" },
          "topic": "Simple Interest",
          "subject": "Quant",
          "difficulty": "easy"
        },
        {
          "en": "If x + 1/x = 4, what is x² + 1/x²?",
          "hi": "यदि x + 1/x = 4, तो x² + 1/x² कितना है?",
          "options": {
            "A": { "en": "14", "hi": "14" },
            "B": { "en": "16", "hi": "16" },
            "C": { "en": "12", "hi": "12" },
            "D": { "en": "18", "hi": "18" }
          },
          "correct": "A",
          "explanation": { "en": "(x+1/x)² = x²+1/x²+2 = 16, so x²+1/x² = 14.", "hi": "(x+1/x)² = x²+1/x²+2 = 16, अतः x²+1/x² = 14।" },
          "topic": "Algebra",
          "subject": "Quant",
          "difficulty": "medium"
        }
      ]
